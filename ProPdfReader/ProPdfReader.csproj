<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\ProPdfReader.ico</ApplicationIcon>
    <AssemblyName>ProPdfReader</AssemblyName>
    <RootNamespace>ProPdfReader</RootNamespace>
    <Version>1.0.1</Version>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <AssemblyTitle>Pro PDF Reader</AssemblyTitle>
    <Product>Pro PDF Reader</Product>
    <Company>YRJ Developer</Company>
    <Description>Fast, lightweight PDF reader for Windows.</Description>
    <Copyright>Copyright (c) 2026 YRJ Developer</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PdfPig" Version="0.1.14" />
  </ItemGroup>

</Project>
