<Window x:Class="ProPdfReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProPdfReader"
        xmlns:controls="clr-namespace:ProPdfReader.Controls"
        mc:Ignorable="d"
        Title="Pro PDF Reader"
        MinHeight="520"
        MinWidth="820"
        Height="760"
        Width="1120"
        Background="{StaticResource WindowBackgroundBrush}"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="FileMenuButton"
                            Width="52"
                            Height="30"
                            Click="FileMenuButton_Click"
                            Content="File">
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom">
                            <MenuItem x:Name="FileOpenMenuItem"
                                      Header="Open...     Ctrl+O"
                                      Click="FileOpenMenuItem_Click" />
                            <MenuItem x:Name="FileSaveMenuItem"
                                      Header="Save local state     Ctrl+S"
                                      Click="FileSaveMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="Close     Ctrl+W"
                                      Click="FileCloseMenuItem_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="PreviousButton"
                            Width="34"
                            Height="30"
                            Margin="12,0,0,0"
                            Click="PreviousButton_Click"
                            Content="&lt;" />
                    <TextBox x:Name="PageNumberTextBox"
                             Width="46"
                             Height="28"
                             Margin="8,0,4,0"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             IsEnabled="False"
                             KeyDown="PageNumberTextBox_KeyDown"
                             LostKeyboardFocus="PageNumberTextBox_LostKeyboardFocus"
                             Text="-"
                             ToolTip="Go to page" />
                    <TextBlock x:Name="PageCountText"
                               MinWidth="44"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="/ 0"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <Button x:Name="NextButton"
                            Width="34"
                            Height="30"
                            Click="NextButton_Click"
                            Content="&gt;" />
                    </StackPanel>

                    <Button x:Name="SearchPaneButton"
                            DockPanel.Dock="Right"
                            Width="34"
                            Height="30"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Click="SearchPaneButton_Click"
                            Content="&#xE721;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            ToolTip="Find text (Ctrl+F)" />

                    <TextBlock x:Name="FileNameText"
                               Margin="18,0,8,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontWeight="SemiBold" />
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ZoomOutButton"
                            Width="34"
                            Height="30"
                            Click="ZoomOutButton_Click"
                            Content="&#xE949;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            ToolTip="Zoom out (Ctrl+-)" />
                    <ComboBox x:Name="ZoomModeComboBox"
                              Width="100"
                              Height="30"
                              Margin="4,0"
                              SelectionChanged="ZoomModeComboBox_SelectionChanged"
                              ToolTip="Zoom mode">
                        <ComboBoxItem Tag="FitWidth" Content="Fit width" IsSelected="True" />
                        <ComboBoxItem Tag="FitPage" Content="Fit page" />
                        <ComboBoxItem Tag="0.5" Content="50%" />
                        <ComboBoxItem Tag="0.75" Content="75%" />
                        <ComboBoxItem Tag="1" Content="100%" />
                        <ComboBoxItem Tag="1.25" Content="125%" />
                        <ComboBoxItem Tag="1.5" Content="150%" />
                        <ComboBoxItem Tag="1.75" Content="175%" />
                        <ComboBoxItem Tag="2" Content="200%" />
                    </ComboBox>
                    <Button x:Name="ZoomInButton"
                            Width="34"
                            Height="30"
                            Click="ZoomInButton_Click"
                            Content="&#xE948;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            ToolTip="Zoom in (Ctrl++)" />
                    <Button x:Name="RotateButton"
                            Width="34"
                            Height="30"
                            Margin="4,0,0,0"
                            Click="RotateButton_Click"
                            Content="&#xE7AD;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            ToolTip="Rotate clockwise" />
                    <Border Width="1" Height="22" Margin="10,0,6,0" Background="{StaticResource BorderBrush}" />
                    <Button x:Name="BookmarksPaneButton"
                            Width="34"
                            Height="30"
                            Click="BookmarksPaneButton_Click"
                            Content="&#xE8FD;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            ToolTip="Show bookmarks" />
                    <Button x:Name="BookmarkPageButton"
                            Width="34"
                            Height="30"
                            Margin="4,0,0,0"
                            Click="BookmarkPageButton_Click"
                            Content="&#xE734;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            ToolTip="Bookmark this page" />
                    <Button x:Name="HighlightButton"
                            Width="34"
                            Height="30"
                            Margin="4,0,0,0"
                            Click="HighlightButton_Click"
                            Content="H"
                            FontWeight="Bold"
                            ToolTip="Highlight selected text (Ctrl+Shift+H)" />
                    <Button x:Name="UnderlineButton"
                            Width="34"
                            Height="30"
                            Margin="4,0,0,0"
                            Click="UnderlineButton_Click"
                            Content="U"
                            FontWeight="Bold"
                            ToolTip="Underline selected text (Ctrl+Shift+U)" />
                    <Button x:Name="NoteButton"
                            Width="58"
                            Height="30"
                            Margin="4,0,0,0"
                            Click="NoteButton_Click"
                            Content="Note"
                            ToolTip="Add note to selected text" />
                    <Button x:Name="NotesPaneButton"
                            Width="34"
                            Height="30"
                            Margin="4,0,0,0"
                            Click="NotesPaneButton_Click"
                            Content="&#xE90A;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            ToolTip="Show notes" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="SearchPane"
                Grid.Row="1"
                Padding="10,6"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Width="30"
                        Height="30"
                        Margin="6,0,0,0"
                        Click="CloseSearchPaneButton_Click"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        ToolTip="Close search" />
                <Button x:Name="NextSearchResultButton"
                        DockPanel.Dock="Right"
                        Width="30"
                        Height="30"
                        Margin="4,0,0,0"
                        Click="NextSearchResultButton_Click"
                        Content="&#xE70D;"
                        FontFamily="Segoe MDL2 Assets"
                        ToolTip="Next result" />
                <Button x:Name="PreviousSearchResultButton"
                        DockPanel.Dock="Right"
                        Width="30"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="PreviousSearchResultButton_Click"
                        Content="&#xE70E;"
                        FontFamily="Segoe MDL2 Assets"
                        ToolTip="Previous result" />
                <TextBlock x:Name="SearchStatusText"
                           DockPanel.Dock="Right"
                           MinWidth="92"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Right" />
                <TextBox x:Name="SearchTextBox"
                         Width="320"
                         Height="30"
                         Padding="7,3"
                         VerticalContentAlignment="Center"
                         KeyDown="SearchTextBox_KeyDown"
                         TextChanged="SearchTextBox_TextChanged"
                         ToolTip="Find text in document" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidePane"
                    Grid.Column="0"
                    Width="210"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="12,0,8,0">
                        <Button DockPanel.Dock="Right"
                                Width="30"
                                Height="30"
                                Click="CloseSidePaneButton_Click"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTip="Close side panel" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Document" />
                    </DockPanel>

                    <TabControl x:Name="SidePaneTabs"
                                Grid.Row="1"
                                BorderThickness="0,1,0,0"
                                Background="Transparent">
                        <TabItem Header="Bookmarks">
                            <Grid>
                                <ListBox x:Name="BookmarksList"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         SelectionChanged="BookmarksList_SelectionChanged" />
                                <TextBlock x:Name="EmptyBookmarksText"
                                           Margin="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="No bookmarks yet."
                                           TextAlignment="Center" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Notes">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="42" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <ListBox x:Name="NotesList"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MouseDoubleClick="NotesList_MouseDoubleClick"
                                             SelectionChanged="NotesList_SelectionChanged" />
                                    <TextBlock x:Name="EmptyNotesText"
                                               Margin="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="No notes yet."
                                               TextAlignment="Center" />
                                </Grid>

                                <StackPanel Grid.Row="1"
                                            Margin="8,0"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button x:Name="EditNoteButton"
                                            Width="32"
                                            Height="30"
                                            Click="EditNoteButton_Click"
                                            Content="&#xE70F;"
                                            FontFamily="Segoe MDL2 Assets"
                                            ToolTip="Edit selected note" />
                                    <Button x:Name="DeleteNoteButton"
                                            Width="32"
                                            Height="30"
                                            Margin="4,0,0,0"
                                            Click="DeleteNoteButton_Click"
                                            Content="&#xE74D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            ToolTip="Delete selected note" />
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="ContentsTab"
                                 Header="Contents"
                                 Visibility="Collapsed">
                            <ListBox x:Name="ContentsList"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="ContentsList_SelectionChanged" />
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <ProgressBar x:Name="ReaderProgressBar"
                             Panel.ZIndex="20"
                             Height="2"
                             VerticalAlignment="Top"
                             BorderThickness="0"
                             Foreground="{StaticResource AccentBrush}"
                             IsIndeterminate="True"
                             Visibility="Collapsed" />

                <ListBox x:Name="DocumentPagesList"
                         Background="#121418"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.CanContentScroll="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.ScrollChanged="DocumentPagesList_ScrollChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.CacheLength="1"
                         VirtualizingPanel.CacheLengthUnit="Page"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.VirtualizationMode="Standard"
                         Loaded="DocumentPagesList_Loaded"
                         SizeChanged="DocumentScrollViewer_SizeChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <controls:PdfPageView Width="{Binding DisplayWidth}"
                                                  Height="{Binding DisplayHeight}"
                                                  Loaded="PdfPageView_Loaded" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel x:Name="HomePanel"
                            Width="440"
                            MaxHeight="520"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Width="54"
                           Height="54"
                           HorizontalAlignment="Left"
                           Source="Assets/ProPdfReader.png" />
                    <TextBlock Margin="0,14,0,0"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Text="Pro PDF Reader" />
                    <TextBlock x:Name="HomeMessageText"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Fast, private PDF reading on this device."
                               TextWrapping="Wrap" />
                    <Button Width="118"
                            Height="34"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Left"
                            Click="HomeOpenButton_Click"
                            Content="Open PDF" />
                    <TextBlock Margin="0,28,0,8"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Recent documents" />
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <ListBox x:Name="RecentDocumentsList"
                                     MaxHeight="210"
                                     BorderThickness="0"
                                     SelectionChanged="RecentDocumentsList_SelectionChanged" />
                            <TextBlock x:Name="EmptyRecentText"
                                       Margin="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="No recent PDFs yet." />
                        </Grid>
                    </Border>
                </StackPanel>

                <Border x:Name="LoadingOverlay"
                        Background="#B317191D"
                        Visibility="Collapsed">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="14,8"
                            Background="{StaticResource PanelRaisedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <TextBlock Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Opening PDF..." />
                    </Border>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText"
                       Margin="10,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextTrimming="CharacterEllipsis"
                       Text="Ready" />
        </Border>
    </Grid>
</Window>
