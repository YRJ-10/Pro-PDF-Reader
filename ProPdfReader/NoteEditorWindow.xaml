<Window x:Class="ProPdfReader.NoteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add note"
        Width="480"
        Height="330"
        MinWidth="380"
        MinHeight="260"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#FBFBF8"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="52" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="14,12"
                Background="#F0F0EB"
                BorderBrush="#D8D8D2"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#4D4D47"
                           Text="Selected text" />
                <TextBlock x:Name="SelectedTextPreview"
                           Margin="0,5,0,0"
                           MaxHeight="58"
                           Foreground="#242420"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TextBox x:Name="NoteTextBox"
                 Grid.Row="1"
                 Margin="14"
                 Padding="10"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 AutomationProperties.Name="Note text"
                 FontSize="14"
                 TextChanged="NoteTextBox_TextChanged"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <Border Grid.Row="2"
                BorderBrush="#D8D8D2"
                BorderThickness="0,1,0,0">
            <StackPanel Margin="12,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Width="76"
                        Height="30"
                        IsCancel="True"
                        Content="Cancel" />
                <Button x:Name="SaveButton"
                        Width="76"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="SaveButton_Click"
                        Content="Save"
                        IsDefault="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
