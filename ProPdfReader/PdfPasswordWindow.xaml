<Window x:Class="ProPdfReader.PdfPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password required"
        Width="420"
        Height="235"
        MinWidth="360"
        MinHeight="220"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        Loaded="Window_Loaded">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="17"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   Text="This PDF is password-protected." />
        <TextBlock x:Name="FileNameText"
                   Grid.Row="1"
                   Margin="0,5,0,14"
                   Foreground="{StaticResource MutedTextBrush}"
                   TextTrimming="CharacterEllipsis" />
        <PasswordBox x:Name="PasswordInput"
                     Grid.Row="2"
                     Height="32"
                     Padding="8,4"
                     AutomationProperties.Name="PDF password"
                     PasswordChanged="PasswordInput_PasswordChanged" />
        <TextBlock x:Name="ErrorText"
                   Grid.Row="3"
                   Margin="0,7,0,0"
                   Foreground="{StaticResource DangerBrush}"
                   Text="That password is incorrect. Try again."
                   Visibility="Collapsed" />

        <StackPanel Grid.Row="4"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="76"
                    Height="30"
                    IsCancel="True"
                    Content="Cancel" />
            <Button x:Name="UnlockButton"
                    Width="76"
                    Height="30"
                    Margin="8,0,0,0"
                    Click="UnlockButton_Click"
                    Content="Unlock"
                    IsDefault="True"
                    IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>
